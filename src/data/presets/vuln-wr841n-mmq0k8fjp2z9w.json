  "metadata": {
    "id": "vuln-wr841n-mmq0k8fjp2z9w",
    "name": "TP-Link WR841N - Vulnerability Analysis",
    "description": "Walkthrough completo: identificazione HW, UART, analisi vulnerabilità, firmware dump SPI",
    "createdAt": "2026-03-13T23:00:00.000Z",
    "updatedAt": "2026-03-13T23:03:10.156Z"
  },
  "exerciseConfig": {
    "pcbImage": "/images/preset-vuln-wr841n-mmq0k8fjp2z9w.png",
    "steps": [
      {
        "id": "step-va-1",
        "title": "Identificazione Hardware",
        "description": "Osserva la PCB del router TP-Link WR841N e identifica i componenti principali. Utilizza la lente di ingrandimento per ispezionare i chip e leggere le sigle stampate sui componenti.",
        "expectedFlag": "flag{QCA9533_W25Q32}",
        "availableTools": [
          "pointer",
          "magnifier"
        ],
        "objectives": [
          {
            "id": "obj-va-hw-cpu",
            "name": "QCA9533",
            "type": "component",
            "componentId": "comp-va-cpu",
            "instruction": "Individua il processore principale (SoC) della board. È il chip più grande e gestisce tutte le operazioni di rete del router.",
            "hint": "Cerca un chip quadrato con la sigla Qualcomm Atheros QCA9533",
            "flagPart": "QCA9533",
            "coords": [
              32.07,
              49.91,
              10.98,
              16.11
            ]
          },
          {
            "id": "obj-va-hw-flash",
            "name": "W25Q32",
            "type": "component",
            "componentId": "comp-va-flash",
            "instruction": "Individua il chip di memoria flash NOR SPI che contiene il firmware (bootloader + kernel + rootfs). È un chip SOP-8 (8 pin).",
            "hint": "Cerca un chip rettangolare più piccolo con la sigla Winbond W25Q32",
            "flagPart": "_W25Q32",
            "coords": [
              60.43,
              51.07,
              11.11,
              28.24
            ]
          }
        ]
      },
      {
        "id": "step-va-2",
        "title": "Connessione UART e Analisi Vulnerabilità",
        "description": "Identifica i pin UART sulla board usando il multimetro per misurare tensione e resistenza. Collega l'adattatore UART per accedere alla console seriale. Esplora il bootloader U-Boot, ottieni accesso root, analizza credenziali e cerca vulnerabilità nel sistema.",
        "expectedFlag": "flag{UART}",
        "availableTools": [
          "pointer",
          "magnifier",
          "multimeter",
          "probes"
        ],
        "objectives": [
          {
            "id": "obj-mmpi2thw759gu",
            "name": "UART Connection & Vulnerability Analysis",
            "type": "pin",
            "instruction": "Collega l'adattatore UART ai pin corretti: TX del dispositivo va a RX dell'adattatore, RX a TX, GND a GND. Usa il multimetro per identificare i pin dalla tensione.",
            "hint": "Il pin TX idles a ~3.3V (dati in uscita). Il GND è a 0V con resistenza ~0Ω.",
            "flagPart": "UART",
            "coords": [
              0,
              0,
              0,
              0
            ],
            "pinConditions": [
              {
                "pinId": "pin-m-2",
                "terminal": "adapter-tx"
              },
              {
                "pinId": "pin-m-1",
                "terminal": "adapter-rx"
              },
              {
                "pinId": "pin-m-3",
                "terminal": "adapter-gnd"
              }
            ],
            "pinLogic": "AND"
          }
        ]
      },
      {
        "id": "step-va-3",
        "title": "Dump Firmware SPI",
        "description": "Collega le sonde SPI ai pin del chip flash Winbond W25Q32 per effettuare il dump del firmware. Questo simula l'utilizzo di un programmatore SPI (es. CH341A) con test clip SOIC-8.",
        "expectedFlag": "flag{SPI_DUMP}",
        "availableTools": [
          "pointer",
          "magnifier",
          "firmware-dump"
        ],
        "objectives": [
          {
            "id": "obj-va-spi",
            "name": "SPI Firmware Dump",
            "type": "pin",
            "instruction": "Collega tutte le 6 sonde SPI ai pin corrispondenti del chip flash: VCC, GND, CS, CLK, MOSI, MISO.",
            "hint": "I pin del chip SOP-8: Pin1=CS (top-left), Pin2=MISO, Pin4=GND, Pin5=MOSI, Pin6=CLK, Pin8=VCC (top-right)",
            "flagPart": "SPI_DUMP",
            "coords": [
              0,
              0,
              0,
              0
            ],
            "pinConditions": [
              {
                "pinId": "pin-spi-cs",
                "terminal": "fw-probe:fw-probe-va-cs"
              },
              {
                "pinId": "pin-spi-miso",
                "terminal": "fw-probe:fw-probe-va-miso"
              },
              {
                "pinId": "pin-spi-gnd",
                "terminal": "fw-probe:fw-probe-va-gnd"
              },
              {
                "pinId": "pin-spi-mosi",
                "terminal": "fw-probe:fw-probe-va-mosi"
              },
              {
                "pinId": "pin-spi-clk",
                "terminal": "fw-probe:fw-probe-va-clk"
              },
              {
                "pinId": "pin-spi-vcc",
                "terminal": "fw-probe:fw-probe-va-vcc"
              }
            ],
            "pinLogic": "AND"
          }
        ]
      }
    ],
