% Aggiungere le voci bibliografiche in formato BibTeX.
%
% Esempio:
%
% @article{author2024title,
%     author  = {Nome Cognome},
%     title   = {Titolo dell'articolo},
%     journal = {Nome del journal},
%     year    = {2024},
%     volume  = {1},
%     pages   = {1--10}
% }
%
% @inproceedings{author2024conf,
%     author    = {Nome Cognome},
%     title     = {Titolo del paper},
%     booktitle = {Nome della conferenza},
%     year      = {2024},
%     pages     = {1--10}
% }
%
% @book{author2024book,
%     author    = {Nome Cognome},
%     title     = {Titolo del libro},
%     publisher = {Editore},
%     year      = {2024}
% }